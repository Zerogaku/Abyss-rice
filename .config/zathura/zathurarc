set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map g goto top

set default-bg                     "#070603"
set default-fg                     "#FAF5E8"
set statusbar-bg                   "#070603"
set statusbar-fg                   "#FAF5E8"
set inputbar-bg                    "#070603"
set inputbar-fg                    "#FAF5E8"
set notification-bg                "#070603"
set notification-fg                "#FAF5E8"
set notification-error-bg          "#070603"
set notification-error-fg          "#FAF5E8"
set notification-warning-bg        "#070603"
set notification-warning-fg        "#FAF5E8"
set highlight-color                "#A08F61"
set highlight-active-color         "#CAAD68"
set completion-bg                  "#A08F61"
set completion-fg                  "#CAAD68"
set completion-highlight-bg        "#A08F61"
set completion-highlight-fg        "#CAAD68"
set recolor-lightcolor             "#070603"
set recolor-darkcolor              "#FAF5E8"
