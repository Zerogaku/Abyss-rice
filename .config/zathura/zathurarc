set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map g goto top

set default-bg                     "#030302"
set default-fg                     "#F6F2E7"
set statusbar-bg                   "#030302"
set statusbar-fg                   "#F6F2E7"
set inputbar-bg                    "#030302"
set inputbar-fg                    "#F6F2E7"
set notification-bg                "#030302"
set notification-fg                "#F6F2E7"
set notification-error-bg          "#030302"
set notification-error-fg          "#F6F2E7"
set notification-warning-bg        "#030302"
set notification-warning-fg        "#F6F2E7"
set highlight-color                "#979AA0"
set highlight-active-color         "#C1AD88"
set completion-bg                  "#979AA0"
set completion-fg                  "#C1AD88"
set completion-highlight-bg        "#979AA0"
set completion-highlight-fg        "#C1AD88"
set recolor-lightcolor             "#030302"
set recolor-darkcolor              "#F6F2E7"
